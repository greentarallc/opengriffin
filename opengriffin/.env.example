# ══════════════════════════════════════════
# OpenGriffin — Configuration
# Only 2 API keys needed!
# ══════════════════════════════════════════

# Telegram Bot (required — @BotFather → /newbot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenRouter (required — openrouter.ai → 300+ AI models)
OPENROUTER_API_KEY=your_openrouter_key

# fal.ai (optional — fal.ai → image & video generation)
FAL_API_KEY=your_fal_key

# Stripe (optional — enables /topup, /subscribe, /billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# Database
DB_PATH=./data/opengriffin.db

# Defaults
DEFAULT_AGENT=chief-of-staff
SYSTEM_TIMEZONE=America/Chicago

# Scheduler
ENABLE_SCHEDULER=true
MORNING_BRIEF_HOUR=7
EVENING_REVIEW_HOUR=20

# Access control
ADMIN_TELEGRAM_IDS=your_telegram_user_id
